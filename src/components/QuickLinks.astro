---
const cards = [
  {
    id: 'psia',
    heading: 'Penn State Investment Association',
    body: 'The Penn State Investment Association (PSIA) is the feeder organization for the Nittany Lion Fund, where over 200 students meet to learn fundamental financial concepts.',
    href: '/psia',
    cta: 'Learn about PSIA',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
    </svg>`,
  },
  {
    id: 'placement',
    heading: 'Wall Street Job Placement',
    body: 'We have placed over 350 NLF alumni into prestigious financial institutions across the world since our inception in 2005.',
    href: '/job-placement',
    cta: 'View Placements',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
    </svg>`,
  },
  {
    id: 'prospective',
    heading: 'Prospective Students',
    body: 'Penn State students are welcome to learn about NLF news, events, and opportunities.',
    href: '/prospective-students',
    cta: 'Explore Opportunities',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>`,
  },
];
---

<section
  id="quick-links"
  class="py-24 sm:py-32"
  style="background: var(--color-navy);"
  aria-labelledby="quick-links-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <p class="section-label mb-3" style="color: var(--color-pugh);">Explore</p>
      <h2
        id="quick-links-heading"
        class="font-serif font-bold text-3xl sm:text-4xl text-white"
      >
        What We Offer
      </h2>
    </div>

    <div class="reveal-group grid grid-cols-1 md:grid-cols-3 gap-6">
      {cards.map((card) => (
        <a
          href={card.href}
          class="group relative flex flex-col p-8 rounded-2xl border transition-all duration-300 cursor-pointer focus-visible:ring-2 focus-visible:ring-pugh"
          style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1);"
          aria-describedby={`card-body-${card.id}`}
        >
          <!-- Icon -->
          <div
            class="flex items-center justify-center w-14 h-14 rounded-xl mb-6 text-white transition-colors duration-300 group-hover:bg-opacity-100"
            style="background: var(--color-beaver);"
            set:html={card.icon}
          />

          <!-- Content -->
          <h3 class="font-serif font-semibold text-xl text-white mb-3 leading-snug">
            {card.heading}
          </h3>
          <p id={`card-body-${card.id}`} class="text-sm leading-relaxed flex-1" style="color: rgba(255,255,255,0.62);">
            {card.body}
          </p>

          <!-- CTA -->
          <div class="mt-6 flex items-center gap-2 text-sm font-semibold transition-colors duration-200" style="color: var(--color-pugh);">
            {card.cta}
            <svg
              class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <!-- Hover border accent -->
          <div
            class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="background: var(--color-pugh);"
            aria-hidden="true"
          ></div>
        </a>
      ))}
    </div>

  </div>
</section>
