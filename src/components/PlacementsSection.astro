---
import data from '../data/class-of-2026.json';
const firms = data.firms;
---

<section
  id="placements"
  class="py-24 sm:py-32 bg-white"
  aria-labelledby="placements-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <p class="section-label mb-3">Our Alumni Network</p>
      <h2
        id="placements-heading"
        class="font-serif font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight"
        style="color: var(--color-navy);"
      >
        Nittany Lion Fund Full Time Placements
      </h2>
      <p class="mt-2 text-base font-medium" style="color: var(--color-slate);">
        Class of 2026
      </p>
    </div>

    <!-- Logo grid: 5 per row, last row centered -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem;">
      {firms.map((firm) => (
        <div
          class="flex items-center justify-center"
          style="flex: none; width: calc((100% - 6rem) / 5);"
          title={firm.name}
        >
          <img
            src={firm.logo}
            alt={firm.name}
            class="object-contain transition-all duration-200 hover:-translate-y-px"
            style="height: 120px; width: 100%; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.15));"
            loading="lazy"
            onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
          />
          <span
            class="items-center justify-center text-xs font-semibold text-center px-2 leading-tight rounded"
            style="display:none; height:120px; width:100%; color: var(--color-navy); background: rgba(0,30,68,0.07);"
          >
            {firm.name}
          </span>
        </div>
      ))}
    </div>

    <!-- View all -->
    <div class="mt-12 text-center reveal">
      <a
        href="/job-placement"
        class="inline-flex items-center gap-2 text-sm font-semibold border-b-2 pb-0.5 transition-colors"
        style="color: var(--color-navy); border-color: var(--color-pugh);"
      >
        View All Placements
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

  </div>
</section>
