---
import Layout from '../layouts/Layout.astro';
import PlacementsSection from '../components/PlacementsSection.astro';
---

<Layout
  title="Prospective Students"
  description="Join the Nittany Lion Fund — a student-managed investment fund at Penn State's Smeal College of Business. Learn about opportunities for Penn State and high school students."
>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section
    class="relative flex items-center justify-center overflow-hidden"
    style="min-height: 52vh; background-color: var(--color-navy);"
    aria-labelledby="ps-hero-heading"
  >
    <!-- Background image (add trading room photo to /public/images/trading-room.jpg) -->
    <div
      class="absolute inset-0 bg-cover bg-no-repeat"
      aria-hidden="true"
      style="
        background-image: url('/images/prospective-students.jpg');
        background-position: center 20%;
        background-color: var(--color-navy);
      "
    ></div>
    <!-- Overlay — darkens the image so text is legible -->
    <div
      class="absolute inset-0"
      aria-hidden="true"
      style="background: linear-gradient(160deg, rgba(0,16,48,0.80) 0%, rgba(0,30,68,0.85) 100%);"
    ></div>

    <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 py-24 max-w-3xl mx-auto">
      <p class="section-label mb-4" style="color: var(--color-pugh);">Join Us</p>
      <h1
        id="ps-hero-heading"
        class="font-serif font-bold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight tracking-tight"
        style="animation: fade-up 0.8s var(--ease-smooth) 0.1s both;"
      >
        Prospective Students
      </h1>
      <p
        class="mt-4 text-white/75 text-lg sm:text-xl font-light tracking-wide"
        style="animation: fade-up 0.8s var(--ease-smooth) 0.25s both;"
      >
        Open doors to your future with real-world experience
      </p>
    </div>
  </section>

  <!-- ── Apply section ─────────────────────────────────────────── -->
  <section
    class="pt-20 sm:pt-28 pb-10 sm:pb-14 bg-white"
    aria-labelledby="apply-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">

        <!-- Left: apply copy -->
        <div class="reveal">
          <p class="section-label mb-4">Get Involved</p>
          <h2
            id="apply-heading"
            class="font-serif font-bold text-3xl sm:text-4xl leading-tight mb-6"
            style="color: var(--color-navy);"
          >
            Apply for the Nittany Lion Fund
          </h2>
          <p class="text-base sm:text-lg leading-relaxed" style="color: var(--color-charcoal);">
            Thank you for your interest in joining the Nittany Lion Fund! Through our educational
            curriculum, which includes stock valuation and modeling, portfolio management, and visits
            from industry professionals, we aim to give students the skills and knowledge they need
            to get placed into a rewarding career after graduation and beyond. Learn about a day in
            the life in the Nittany Lion Fund.
          </p>
        </div>

        <!-- Right: student type cards — stacked -->
        <div class="reveal flex flex-col gap-5" style="transition-delay: 150ms;">

          <!-- Penn State Students -->
          <div
            class="rounded-2xl border flex flex-col gap-4"
            style="border-color: #E8ECF0; background: var(--color-cream); padding: 1.5rem 1.75rem;"
          >
            <div class="flex items-center gap-3">
              <div
                class="inline-flex items-center justify-center w-9 h-9 rounded-lg flex-shrink-0"
                style="background: var(--color-navy);"
                aria-hidden="true"
              >
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              </div>
              <h3 class="font-serif font-semibold text-lg" style="color: var(--color-navy);">
                Penn State Students
              </h3>
            </div>
            <p class="text-sm leading-relaxed" style="color: var(--color-charcoal);">
              If you are a current Penn State student, consider joining the Penn State Investment
              Association (PSIA), the feeder organization for the Nittany Lion Fund.
            </p>
            <a
              href="/psia"
              class="self-start inline-flex items-center gap-1.5 rounded-full font-semibold text-white transition-all hover:opacity-85"
              style="background: var(--color-navy); font-size: 0.8125rem; padding: 0.45rem 1.1rem;"
            >
              Join PSIA
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

          <!-- High School Students -->
          <div
            class="rounded-2xl border flex flex-col gap-4"
            style="border-color: #E8ECF0; background: var(--color-cream); padding: 1.5rem 1.75rem;"
          >
            <div class="flex items-center gap-3">
              <div
                class="inline-flex items-center justify-center w-9 h-9 rounded-lg flex-shrink-0"
                style="background: var(--color-beaver);"
                aria-hidden="true"
              >
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="font-serif font-semibold text-lg" style="color: var(--color-navy);">
                High School Students
              </h3>
            </div>
            <p class="text-sm leading-relaxed" style="color: var(--color-charcoal);">
              Are you a high school student or class planning to visit Penn State and want to see
              the Nittany Lion Fund in action? Contact us for more information.
            </p>
            <a
              href="/contact"
              class="self-start inline-flex items-center gap-1.5 rounded-full font-semibold text-white transition-all hover:opacity-85"
              style="background: var(--color-beaver); font-size: 0.8125rem; padding: 0.45rem 1.1rem;"
            >
              Contact Us
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

        </div>

      </div> <!-- end grid -->
    </div>
  </section>

  <!-- ── Placements preview (reused from home page) ─────────────── -->
  <PlacementsSection />

</Layout>
