---

<Layout
  title="Job Placement"
  description="Since 2005, the Nittany Lion Fund has placed over 300 alumni in prestigious firms across Wall Street and the world."
>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section
    class="relative flex items-center justify-center overflow-hidden"
    style="min-height: 50vh; background-color: var(--color-navy);"
    aria-labelledby="jp-hero-heading"
  >
    <!-- Wall Street background image -->
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      aria-hidden="true"
      style="background-image: url('/images/wall-street.jpg');"
    ></div>
    <!-- Dark overlay — light enough to let the image show through -->
    <div
      class="absolute inset-0"
      aria-hidden="true"
      style="background: linear-gradient(160deg, rgba(0,10,30,0.52) 0%, rgba(0,20,50,0.60) 100%);"
    ></div>

    <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 py-28 max-w-4xl mx-auto">
      <p class="section-label mb-5" style={`color: ${YELLOW};`}>Alumni Network</p>
      <h1
        id="jp-hero-heading"
        class="font-serif font-bold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight tracking-tight"
        style="animation: fade-up 0.8s var(--ease-smooth) 0.1s both;"
      >
        Initial Full-time Placements<br class="hidden sm:block" />
        Since Inception
      </h1>
    </div>
  </section>

  <!-- ── Attracting section ────────────────────────────────────── -->
  <section
    class="py-20 sm:py-24"
    style="background-color: var(--color-navy);"
    aria-labelledby="attracting-heading"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2
        id="attracting-heading"
        class="font-serif font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight mb-6"
        style={`color: ${YELLOW};`}
      >
        Attracting the eyes of worldwide firms
      </h2>
      <p class="text-base sm:text-lg leading-relaxed text-white/80 mb-10">
        Since the Nittany Lion Fund's inception in 2005, we have placed over 300 alumni in
        prestigious companies on Wall Street and across the world. Our placement career paths
        include investment banking, private equity, sales &amp; trading, asset management,
        private wealth management, research, advisory/consulting, corporate finance, and more.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-full font-bold transition-all hover:brightness-90"
        style={`background: ${YELLOW}; color: #001030; padding: 0.75rem 2rem; font-size: 0.9375rem;`}
      >
        Contact Us
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Placements grid ───────────────────────────────────────── -->
  <section class="bg-white" style="padding-top: 6rem; padding-bottom: 7rem;" aria-labelledby="placements-grid-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-14 reveal">
        <p class="section-label mb-3">Our Alumni</p>
        <h2
          id="placements-grid-heading"
          class="font-serif font-bold text-3xl sm:text-4xl"
          style="color: var(--color-navy);"
        >
          Initial Full-Time Placements
        </h2>
      </div>

      <!-- Categories -->
      {categories.map((cat, idx) => (
        <div>
          {/* Separator — skip before first category */}
          {idx > 0 && (
            <div
              aria-hidden="true"
              style="width: 80%; height: 1px; background: #222; margin: 2.75rem auto;"
            ></div>
          )}

          <div class="reveal">
            <!-- Subsection heading -->
            <h3
              class="font-sans font-semibold text-base sm:text-lg mb-5"
              style="color: var(--color-navy);"
            >
              {cat.name}
            </h3>

            <!-- Logo grid: 5 per row, last row centered (pyramid effect) -->
            <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem;">
              {cat.firms.map((firm) => (
                <div
                  class="flex items-center justify-center"
                  style="flex: none; width: calc((100% - 6rem) / 5);"
                  title={firm.name}
                >
                  <img
                    src={firm.logo}
                    alt={firm.name}
                    class="object-contain transition-all duration-200 hover:-translate-y-px"
                    style="height: 120px; width: 100%; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.15));"
                    loading="lazy"
                    onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
                  />
                  <span
                    class="items-center justify-center text-xs font-semibold text-center px-2 leading-tight rounded"
                    style="display:none; height:120px; width:100%; color: var(--color-navy); background: rgba(0,30,68,0.07);"
                  >
                    {firm.name}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}

    </div>
  </section>

</Layout>
