---
import Layout from '../../layouts/Layout.astro';
import teamData from '../../data/team.json';

export function getStaticPaths() {
  const all = [
    ...teamData.executive_board.map((p) => ({ ...p, group: 'Executive Board',  backHash: 'exec' })),
    ...teamData.leadership.map((p)       => ({ ...p, group: 'Leadership',       backHash: 'leadership' })),
    ...teamData.fund_managers.map((p)    => ({ ...p, group: 'Fund Managers',    backHash: 'managers' })),
  ];
  return all.map((person) => ({
    params: { slug: person.slug },
    props:  { person },
  }));
}

const { person } = Astro.props as {
  person: {
    slug: string; name: string; position: string; photo: string;
    bio: string; linkedin: string; email: string;
    group: string; backHash: string;
    sector?: string;
  };
};

const displayName = person.name || 'TBD';
const hasBio      = Boolean(person.bio);
const hasLinkedIn = Boolean(person.linkedin);
const hasEmail    = Boolean(person.email);
---

<Layout
  title={displayName === 'TBD' ? person.position : displayName}
  description={`${displayName} — ${person.position} at the Nittany Lion Fund.`}
>

  <!-- ── Hero wrapper with background image ───────────────────── -->
  <div class="relative overflow-hidden" style="background: var(--color-navy);">
    <div class="absolute inset-0 bg-cover bg-no-repeat" aria-hidden="true"
      style="background-image: url('/images/Nittany-Lion-Meet-Team-Base.jpg'); background-position: center center;"></div>
    <div class="absolute inset-0" aria-hidden="true"
      style="background: linear-gradient(160deg, rgba(0,10,30,0.72) 0%, rgba(0,20,55,0.82) 100%);"></div>

  <!-- ── Back nav ──────────────────────────────────────────────── -->
  <div class="relative z-10" style="padding: 5.5rem 1.5rem 0;">
    <div class="max-w-5xl mx-auto">
      <a
        href={`/team#${person.backHash}`}
        class="inline-flex items-center gap-2 text-sm font-semibold transition-opacity hover:opacity-70"
        style="color: rgba(255,255,255,0.70);"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to {person.group}
      </a>
    </div>
  </div>

  <!-- ── Profile hero band ─────────────────────────────────────── -->
  <div class="relative z-10" style="padding: 2.5rem 1.5rem 4rem;">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center sm:items-end gap-6">
      <!-- Avatar -->
      <div
        class="rounded-2xl overflow-hidden flex-shrink-0"
        style="width: 160px; height: 160px; background: #2A3F6A; box-shadow: 0 8px 32px rgba(0,0,0,0.35);"
      >
        {person.photo ? (
          <img
            src={person.photo}
            alt={displayName}
            class="w-full h-full object-cover object-top"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center">
            <svg style="width:4rem;height:4rem;color:#6B7FA8;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
        )}
      </div>

      <!-- Name / role -->
      <div>
        <p class="text-xs font-bold tracking-widest uppercase mb-1" style="color: var(--color-pugh);">
          {person.group}{person.sector ? ` · ${person.sector}` : ''}
        </p>
        <h1 class="font-serif font-bold text-white text-3xl sm:text-4xl lg:text-5xl leading-tight">
          {displayName}
        </h1>
        <p class="mt-1 text-base font-medium" style="color: rgba(255,255,255,0.60);">
          {person.position}
        </p>
      </div>
    </div>
  </div>
  </div><!-- end hero wrapper -->

  <!-- ── Profile body ───────────────────────────────────────────── -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">

        <!-- Bio -->
        {hasBio ? (
          <p class="text-base sm:text-lg leading-relaxed" style="color: var(--color-charcoal);">
            {person.bio}
          </p>
        ) : (
          <p class="text-base italic" style="color: var(--color-slate);">
            Bio coming soon.
          </p>
        )}

        <!-- Contact links -->
        {(hasLinkedIn || hasEmail) && (
          <div class="flex flex-wrap gap-3 mt-8">
            {hasLinkedIn && (
              <a
                href={person.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 font-semibold rounded-full transition-all hover:opacity-85 hover:-translate-y-px"
                style="background: var(--color-navy); color: #fff; font-size: 0.875rem; padding: 0.6rem 1.5rem;"
              >
                <!-- LinkedIn icon -->
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
            )}
            {hasEmail && (
              <a
                href={`mailto:${person.email}`}
                class="inline-flex items-center gap-2 font-semibold rounded-full transition-all hover:opacity-85 hover:-translate-y-px"
                style="background: var(--color-cream); color: var(--color-navy); border: 2px solid #D0D5DE; font-size: 0.875rem; padding: 0.6rem 1.5rem;"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                Email
              </a>
            )}
          </div>
        )}

      </div>
    </div>
  </section>

</Layout>
